# Shopify Storefront API credentials
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Your Shopify store domain (e.g. ventality-2.myshopify.com)
NEXT_PUBLIC_SHOPIFY_DOMAIN=ventality-2.myshopify.com

# Shopify Storefront API access token
# Get this from: Shopify Admin → Settings → Apps and sales channels → Develop apps
# Permissions needed: unauthenticated_read_product_listings, unauthenticated_write_checkouts,
#                    unauthenticated_read_checkouts, unauthenticated_write_customers,
#                    unauthenticated_read_customers
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here
