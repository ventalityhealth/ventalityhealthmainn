{%- comment -%} Open Graph + Twitter meta tags {%- endcomment -%}
{%- if template contains 'product' and product -%}
  <meta property="og:type" content="product">
  <meta property="og:title" content="{{ product.title | escape }}">
  <meta property="og:description" content="{{ product.description | strip_html | truncate: 160 | escape }}">
  {%- if product.featured_image -%}
    <meta property="og:image" content="{{ product.featured_image | image_url: width: 1200 }}">
  {%- endif -%}
{%- elsif template contains 'collection' and collection -%}
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ collection.title | escape }}">
  <meta property="og:description" content="{{ collection.description | strip_html | truncate: 160 | escape }}">
{%- else -%}
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
  <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
{%- endif -%}
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta name="twitter:card" content="summary_large_image">
{%- if settings.social_twitter != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter | replace: 'https://twitter.com/', '@' | replace: 'https://x.com/', '@' }}">
{%- endif -%}
