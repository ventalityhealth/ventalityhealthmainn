<section class="vt-container" style="padding: clamp(80px, 10vw, 120px) 0;">
  <div style="max-width: 440px; margin: 0 auto;">
    <h1 class="vt-heading-lg vt-mb-8 vt-text-center">Activate your account</h1>
    <div class="vt-panel vt-panel-pad-lg">
      {%- form 'activate_customer_password' -%}
        {%- if form.errors -%}
          <div class="vt-mb-4" style="color: var(--vt-warm);">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div style="display:flex;flex-direction:column;gap:12px;">
          <input type="password" name="customer[password]" class="vt-input" placeholder="Password" required>
          <input type="password" name="customer[password_confirmation]" class="vt-input" placeholder="Confirm password" required>
          <button type="submit" class="vt-button-primary vt-mt-4">Activate account</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>
