<section class="vt-section">
  <div class="vt-container vt-text-center" style="max-width:720px;">
    {%- if section.settings.eyebrow != blank -%}
      <div class="vt-eyebrow vt-mb-6">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="vt-heading-lg vt-mb-6">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="vt-copy">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="vt-button-secondary vt-mt-8">
        {{ section.settings.cta_label }}{%- render 'icon-arrow-right' -%}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text",     "id": "heading", "label": "Heading", "default": "About Ventality" },
    { "type": "richtext", "id": "body",    "label": "Body" },
    { "type": "text",     "id": "cta_label", "label": "Button label" },
    { "type": "url",      "id": "cta_link",  "label": "Button link" }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
