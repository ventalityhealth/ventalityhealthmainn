<section class="vt-section">
  <div class="vt-container">
    <div class="vt-panel vt-cta-panel">
      {%- if section.settings.eyebrow != blank -%}
        <div class="vt-eyebrow vt-mb-6">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="vt-heading-lg vt-mb-4" style="max-width:560px;margin-inline:auto;">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}
        <p class="vt-copy vt-mb-8" style="max-width:420px;margin-inline:auto;font-size:var(--vt-text-sm);">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'vt-cta-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="vt-input"
          placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
          required
          autocomplete="email"
          aria-label="Email"
        >
        <button type="submit" class="vt-button-primary" style="flex:0 0 auto;">
          {{ 'general.newsletter.submit' | t }}
        </button>
        {%- if form.posted_successfully? -%}
          <p class="vt-cta-note" style="flex:0 0 100%;color:var(--vt-success);">{{ 'general.newsletter.success' | t }}</p>
        {%- elsif form.errors -%}
          <p class="vt-cta-note" style="flex:0 0 100%;color:var(--vt-warm);">{{ form.errors.messages.email }}</p>
        {%- endif -%}
      {%- endform -%}

      <p class="vt-cta-note">{{ 'general.newsletter.privacy_note' | t }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter CTA",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Stay Informed" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Evidence-based updates.<br><span style=\"color: var(--vt-muted)\">No noise.</span></p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "New products, science reviews, and formulation updates. No spam — unsubscribe anytime."
    }
  ],
  "presets": [
    { "name": "Newsletter CTA" }
  ]
}
{% endschema %}
