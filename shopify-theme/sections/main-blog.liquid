<section class="vt-container" style="padding: clamp(80px, 10vw, 120px) 0;">
  <div class="vt-text-center vt-mb-8">
    <p class="label-sm vt-mb-2">Blog</p>
    <h1 class="vt-heading-lg">{{ blog.title }}</h1>
  </div>

  {%- paginate blog.articles by 9 -%}
    {%- if blog.articles.size > 0 -%}
      <div class="vt-grid-3">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="vt-panel vt-panel--interactive vt-panel-pad-md vt-cap-card">
            {%- if article.image -%}
              <div class="vt-mb-6" style="border-radius:12px;overflow:hidden;background:#0E131C;">
                <img src="{{ article.image | image_url: width: 720 }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="lazy" style="width:100%;aspect-ratio:16/9;object-fit:cover;">
              </div>
            {%- endif -%}
            <p class="label-xs vt-mb-2">{{ article.published_at | date: '%b %-d, %Y' }}</p>
            <p class="vt-cap-label">{{ article.title }}</p>
            <p class="vt-cap-body">{{ article.excerpt | default: article.content | strip_html | truncatewords: 24 }}</p>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="vt-pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">{{ 'general.pagination.previous' | t }}</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}{%- if part.title == paginate.current_page -%}<span class="vt-pagination-current">{{ part.title }}</span>{%- else -%}<span>{{ part.title }}</span>{%- endif -%}{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }}</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- else -%}
      <p class="vt-copy vt-text-center">No articles yet.</p>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
