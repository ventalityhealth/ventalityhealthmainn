<footer class="vt-footer" role="contentinfo">
  <div class="vt-container vt-footer-inner">
    <div class="vt-footer-grid">
      <div class="vt-footer-brand">
        <a href="{{ routes.root_url }}" class="vt-logo">
          {%- if settings.logo -%}
            <img
              src="{{ settings.logo | image_url: width: 64 }}"
              alt="{{ settings.brand_name | default: shop.name | escape }}"
              width="28" height="28"
              style="width:28px;height:28px"
            >
          {%- endif -%}
          <span class="vt-logo-text">{{ settings.brand_name | default: shop.name }}</span>
        </a>
        {%- if section.settings.brand_description != blank -%}
          <p class="vt-footer-desc">{{ section.settings.brand_description }}</p>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div {{ block.shopify_attributes }}>
            <p class="vt-footer-heading">{{ block.settings.heading }}</p>
            {%- assign list = linklists[block.settings.menu] -%}
            {%- if list and list.links.size > 0 -%}
              <ul class="vt-footer-list">
                {%- for link in list.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if settings.footer_disclaimer != blank -%}
      <div class="vt-footer-disclaimer">{{ settings.footer_disclaimer }}</div>
    {%- endif -%}
    {%- if settings.footer_copyright != blank -%}
      <p class="vt-footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ settings.footer_copyright }}</p>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium supplements formulated for performance. Manufactured in cGMP-compliant, FDA-registered facilities."
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Shop" } },
        { "type": "link_column", "settings": { "heading": "Company" } },
        { "type": "link_column", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
